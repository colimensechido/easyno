# Copia este archivo a .env y rellena los valores antes de ejecutar docker compose

# ── Caddy / TLS ───────────────────────────────────────────────────────────────
ACME_EMAIL=admin@morphyss.com
# Se usa Cloudflare API token, no GoDaddy
CLOUDFLARE_API_TOKEN=asdassd

# Dominio raíz (sin https://, sin trailing slash)
# Ejemplo: casino.morphyss.com
ROOT_DOMAIN=casino.morphyss.com

# ── App ───────────────────────────────────────────────────────────────────────
# Secreto para firmar los JWT — usa una cadena larga y aleatoria
# Ejemplo: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-seguro

# Origen CORS permitido (debe coincidir con ROOT_DOMAIN con https)
CLIENT_ORIGIN=https://casino.morphyss.com
