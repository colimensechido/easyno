# Copia este archivo a .env y rellena los valores antes de ejecutar docker compose

# ── Caddy / TLS ───────────────────────────────────────────────────────────────
ACME_EMAIL=admin@morphyss.com
# Se usa Cloudflare API token, no GoDaddy
CLOUDFLARE_API_TOKEN=asdassd

# Dominio raíz (sin https://, sin trailing slash)
# Ejemplo: casino.morphyss.com
ROOT_DOMAIN=casino.morphyss.com

# ── App ───────────────────────────────────────────────────────────────────────
# Secreto para firmar los JWT — usa una cadena larga y aleatoria
# Ejemplo: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-seguro

# Origen CORS permitido (debe coincidir con ROOT_DOMAIN con https)
CLIENT_ORIGIN=https://casino.morphyss.com

# ── Mercado Pago (recargas EyCon) ─────────────────────────────────────────────
# Credenciales desde https://www.mercadopago.com.mx/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-tu_access_token
MERCADOPAGO_PUBLIC_KEY=APP_USR-tu_public_key
MERCADOPAGO_CHECKOUT_MODE=production
# Firma secreta de Webhooks > Configurar notificaciones en Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=reemplaza-con-la-clave-secreta-del-webhook
# Recomendado: ID numerico de la cuenta vendedora para validar el receptor del pago
MERCADOPAGO_COLLECTOR_ID=

# URLs publicas HTTPS (el Caddyfile expone api.{$ROOT_DOMAIN} para el backend)
MERCADOPAGO_PUBLIC_SITE_URL=https://casino.morphyss.com
MERCADOPAGO_PUBLIC_API_URL=https://api.casino.morphyss.com

# Opcional: sobreescribir URLs concretas (si no, se usa /payment-return.html en el frontend)
# MERCADOPAGO_SUCCESS_URL=https://casino.morphyss.com/payment-return.html?status=success
# MERCADOPAGO_PENDING_URL=
# MERCADOPAGO_FAILURE_URL=
# MERCADOPAGO_WEBHOOK_URL=
