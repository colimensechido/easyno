MERCADOPAGO_PUBLIC_KEY=APP_USR-your_public_key
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your_access_token
MERCADOPAGO_CHECKOUT_MODE=production

# Si tienes dominio publico HTTPS, define esto para back_urls y webhook automaticos.
MERCADOPAGO_PUBLIC_SITE_URL=https://your-frontend-public-url
MERCADOPAGO_PUBLIC_API_URL=https://your-backend-public-url

# Alternativa: define estas 4 URLs directamente si no usas las de arriba.
MERCADOPAGO_SUCCESS_URL=
MERCADOPAGO_PENDING_URL=
MERCADOPAGO_FAILURE_URL=
MERCADOPAGO_WEBHOOK_URL=
